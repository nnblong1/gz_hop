    <!-- ============================================================
         JOINT POSITION CONTROLLERS
         PID đã tune lại: p_gain giảm, d_gain tăng mạnh → chống overshoot
         cmd_max/cmd_min giới hạn lực tối đa tránh violent correction
         ============================================================ -->
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>Revolute_20</joint_name>
      <topic>/model/x500_hop/joint/Revolute_20/cmd_pos</topic>
      <p_gain>50.0</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>20.0</d_gain>
      <i_max>0.5</i_max>
      <i_min>-0.5</i_min>
      <cmd_max>50.0</cmd_max>
      <cmd_min>-50.0</cmd_min>
    </plugin>
