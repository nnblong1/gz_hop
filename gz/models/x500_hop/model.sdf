      </collision>
    </link>

    <!-- Revolute_28: forearm pitch -->
    <joint name="Revolute_28" type="revolute">
      <parent>servo5_1</parent>
      <child>link5_1</child>
      <pose>0.0 -0.0148 0.00995 0 0 0</pose>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-2.356194</lower><upper>2.356194</upper>
          <effort>100</effort><velocity>5</velocity>
        </limit>
        <dynamics>
          <damping>5.0</damping>
          <friction>0.3</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

