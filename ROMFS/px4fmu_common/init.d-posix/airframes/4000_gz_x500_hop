#!/bin/sh
#
# @name HOP - UAM with 6-DoF Arm
#
# @url https://docs.px4.io/main/en/frames_multicopter/
#
# @type Quadrotor x
# @class Copter
#
# @maintainer wicom
#
# @board px4_fmu-v2 exclude
# @board bitcraze_crazyflie exclude
# @board px4_fmu-v6x exclude
# @board ark_fmu-v6x exclude
#

. ${R}etc/init.d/rc.mc_defaults

PX4_SIMULATOR=${PX4_SIMULATOR:=gz}
PX4_GZ_WORLD=${PX4_GZ_WORLD:=default}
PX4_SIM_MODEL=${PX4_SIM_MODEL:=x500_hop}
param set-default SIM_GZ_EN 1

# Mixer: quad_x — SunnySky X2212-13 KV980 II
# Motor numbering must match x500_hop/model.sdf plugin order:
#   motor 0 -> quat_2_1 -> rear-left   -> CCW
#   motor 1 -> quat_4_1 -> front-right -> CCW
#   motor 2 -> quat_1_1 -> rear-right  -> CW
#   motor 3 -> quat_3_1 -> front-left  -> CW
param set-default CA_METHOD 2
param set-default CA_ROTOR_COUNT 4
param set-default CA_ROTOR0_AX 0.0
param set-default CA_ROTOR0_AY 0.0
param set-default CA_ROTOR0_AZ -1.0
param set-default CA_ROTOR0_CT 6.5
param set-default CA_ROTOR0_PX -0.159
param set-default CA_ROTOR0_PY -0.159
param set-default CA_ROTOR0_PZ 0.0
param set-default CA_ROTOR1_AX 0.0
param set-default CA_ROTOR1_AY 0.0
param set-default CA_ROTOR1_AZ -1.0
param set-default CA_ROTOR1_CT 6.5
param set-default CA_ROTOR1_PX  0.159
param set-default CA_ROTOR1_PY  0.159
param set-default CA_ROTOR1_PZ 0.0
param set-default CA_ROTOR2_AX 0.0
param set-default CA_ROTOR2_AY 0.0
param set-default CA_ROTOR2_AZ -1.0
param set-default CA_ROTOR2_CT 6.5
param set-default CA_ROTOR2_PX -0.159
param set-default CA_ROTOR2_PY  0.159
param set-default CA_ROTOR2_PZ 0.0
param set-default CA_ROTOR3_AX 0.0
param set-default CA_ROTOR3_AY 0.0
param set-default CA_ROTOR3_AZ -1.0
param set-default CA_ROTOR3_CT 6.5
param set-default CA_ROTOR3_PX  0.159
param set-default CA_ROTOR3_PY -0.159
param set-default CA_ROTOR3_PZ 0.0
param set-default CA_ROTOR0_KM  0.05
param set-default CA_ROTOR1_KM  0.05
param set-default CA_ROTOR2_KM -0.05
param set-default CA_ROTOR3_KM -0.05

# KM follows the flown vehicle params and PX4 x500 convention:
# CCW positive, CW negative.
param set-default SYS_AUTOSTART 4000

# 🔓 Tắt các hàng rào kiểm tra an toàn gây cản trở khi mô phỏng Manual
param set-default CBRK_SUPPLY_CHK 894281  # Bỏ qua check Pin/Nguồn điện
param set-default CBRK_USB_CHK 197848     # Bỏ qua check cắm cáp USB
param set-default CBRK_FLIGHTTERM 121212  # Bỏ qua cấm bay (Flight Termination)
param set-default CBRK_VELPOSERR 201607   # Bỏ qua check lỗi Vận tốc/Vị trí của EKF2
param set-default COM_RCL_EXCEPT 4        # Bỏ qua báo thiếu Tay cầm RC
param set-default COM_ARM_WO_GPS 1        # Cho phép Arm dù chưa có sóng GPS
param set-default COM_POWER_COUNT 0       # Không yêu cầu power module báo cáo (SITL)

# Ép EKF2 hội tụ ngay lập tức bằng cách nới lỏng toàn bộ sai số cho phép
param set-default EKF2_GPS_CHECK 0        # Không kiểm tra chất lượng GPS
param set-default COM_ARM_EKF_POS 5.0     # Nới lỏng check vị trí
param set-default COM_ARM_EKF_VEL 5.0     # Nới lỏng check vận tốc
param set-default COM_ARM_EKF_HGT 5.0     # Nới lỏng check độ cao
param set-default COM_ARM_EKF_YAW 5.0     # Nới lỏng check góc Yaw
param set-default COM_ARM_MAG_ANG 180     # Bỏ qua lỗi la bàn (Magnetometer)

# Battery cell count from the real flown UAM parameter file.
param set-default BAT1_N_CELLS 3

param set-default SIM_GZ_EC_FUNC1 101
param set-default SIM_GZ_EC_FUNC2 102
param set-default SIM_GZ_EC_FUNC3 103
param set-default SIM_GZ_EC_FUNC4 104

param set-default SIM_GZ_EC_MIN1 0
param set-default SIM_GZ_EC_MIN2 0
param set-default SIM_GZ_EC_MIN3 0
param set-default SIM_GZ_EC_MIN4 0

param set-default SIM_GZ_EC_MAX1 2200
param set-default SIM_GZ_EC_MAX2 2200
param set-default SIM_GZ_EC_MAX3 2200
param set-default SIM_GZ_EC_MAX4 2200

param set-default IMU_GYRO_CUTOFF 40
param set-default IMU_DGYRO_CUTOFF 30

param set-default COM_ARM_CHK_ESCS 0
param set-default FD_ESCS_EN 0
param set-default COM_DISARM_PRFLT 0

# ── Pre-arm and estimator thresholds from the real flown UAM baseline ──
param set-default COM_ARM_IMU_ACC 0.7
param set-default COM_ARM_IMU_GYR 0.25
param set-default COM_ARM_EKF_AB 0.0032
param set-default EKF2_ACC_NOISE 0.35
param set-default EKF2_GYR_NOISE 0.015

param set-default MC_AIRMODE 1
# ── Baseline flight stability ──
# Giai đoạn takeoff/hover nền dùng PX4 rate controller nội bộ.
# Chỉ nên bật external rate controller sau khi đã chứng minh hover nền ổn định.
param set-default MC_RATE_EXT_EN 0
# Rate and attitude gains from the real flown UAM parameter file.
param set-default MC_PITCHRATE_D 0.005
# param set-default MC_PITCHRATE_I 0.2
param set-default MC_PITCHRATE_I 0.14
param set-default MC_PITCHRATE_K 1.0
param set-default MC_PITCHRATE_MAX 220
# param set-default MC_PITCHRATE_P 0.15
param set-default MC_PITCHRATE_P 0.12
param set-default MC_PITCH_P 4.8
param set-default MC_ROLLRATE_D 0.0045
# param set-default MC_ROLLRATE_I 0.2
param set-default MC_ROLLRATE_I 0.16
param set-default MC_ROLLRATE_K 1.2
param set-default MC_ROLLRATE_MAX 220
# param set-default MC_ROLLRATE_P 0.15
param set-default MC_ROLLRATE_P 0.14
param set-default MC_ROLL_P 4.8
param set-default MC_YAWRATE_D 0.0
param set-default MC_YAWRATE_I 0.14
param set-default MC_YAWRATE_K 1.1
param set-default MC_YAWRATE_MAX 200
param set-default MC_YAWRATE_P 0.2
param set-default MC_YAW_P 2.8

param set-default MPC_MANTHR_MIN 0.08
param set-default MPC_MAN_TILT_MAX 35
param set-default MPC_MAN_Y_MAX 150
param set-default MPC_MAN_Y_TAU 0.08
param set-default MPC_THR_CURVE 1
# Hover throttle is kept from the SDF mass/thrust estimate, not copied
# from the real vehicle, because the simulated motor constant differs.
param set-default MPC_THR_HOVER 0.375
param set-default MPC_THR_MIN 0.12

param set-default MPC_ACC_DECOUPLE 1
param set-default MPC_ACC_HOR 0.8
param set-default MPC_ACC_HOR_MAX 1.2

param set-default MPC_XY_CRUISE 1
param set-default MPC_XY_ERR_MAX 2.0
param set-default MPC_XY_P 0.65
param set-default MPC_XY_TRAJ_P 0.5
param set-default MPC_XY_VEL_D_ACC 0.15
param set-default MPC_XY_VEL_I_ACC 0.2
param set-default MPC_XY_VEL_MAX 1
param set-default MPC_XY_VEL_P_ACC 1.2

param set-default MPC_Z_P 0.8
param set-default MPC_Z_VEL_D_ACC 0.0
param set-default MPC_Z_VEL_I_ACC 1.2
param set-default MPC_Z_VEL_P_ACC 3

# ── Giới hạn tốc độ và gia tốc theo chiều cao (Chống bay vọt) ──
param set-default MPC_Z_VEL_MAX_UP 0.6
param set-default MPC_Z_VEL_MAX_DN 0.5
param set-default MPC_Z_VEL_ALL 1.0
param set-default MPC_Z_V_AUTO_UP 0.6
param set-default MPC_Z_V_AUTO_DN 0.5
param set-default MPC_ACC_UP_MAX 0.8
param set-default MPC_ACC_DOWN_MAX 0.8
param set-default MPC_TILTMAX_AIR 25
param set-default MPC_TILTMAX_LND 12
param set-default MIS_TAKEOFF_ALT 2.0     # AUTO_TAKEOFF mặc định lên 2m trước khi chuyển sang OFFBOARD hold

param set-default THR_MDL_FAC 0.0
